{
  "name": "pi-dask",
  "version": "0.0.1",
  "description": "Structured choice collection for Pi",
  "type": "module",
  "main": "index.ts",
  "types": "dist/index.d.ts",
  "files": [
    "index.ts",
    "src",
    "dist",
    "README.md",
    "doc/接口契约.md"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "test": "npm run build && node --test test/**/*.test.js",
    "pack:check": "npm pack --dry-run"
  },
  "keywords": [
    "pi-package",
    "pi",
    "structured-question"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@earendil-works/pi-ai": "^0.80.6",
    "@earendil-works/pi-coding-agent": "^0.80.6",
    "@earendil-works/pi-tui": "^0.80.6",
    "typebox": "^1.1.38"
  },
  "devDependencies": {
    "typescript": "^5.8.3"
  },
  "pi": {
    "extensions": [
      "./index.ts"
    ]
  }
}
